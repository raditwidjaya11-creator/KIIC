{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "General spatial land or administrative inquiry from ContactFooter",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "email",
        "subject",
        "message",
        "createdAt"
      ]
    },
    "ExpressionOfInterest": {
      "title": "Expression of Interest",
      "description": "Detailed investor expression of interest for industrial lots in KIIT",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "fullname": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "capital": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "intentNote": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "fullname",
        "company",
        "email",
        "createdAt"
      ]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Meeting consultation appointment for investment assessment",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "meetingType": {
          "type": "string"
        },
        "scheduledDate": {
          "type": "string"
        },
        "scheduledTime": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "meetingType",
        "scheduledDate",
        "scheduledTime",
        "createdAt"
      ]
    },
    "User": {
      "title": "User",
      "description": "Registered portal user directory",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": [
        "email",
        "role",
        "createdAt"
      ]
    },
    "MasterplanZone": {
      "title": "Masterplan Zone",
      "description": "Dynamic mapping of KIIT masterplan segments synced with Firestore",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "nama_zona": {
          "type": "string"
        },
        "kategori": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "luas_ha": {
          "type": "number"
        },
        "investor": {
          "type": "string"
        },
        "nilai_investasi": {
          "type": "string"
        },
        "progress_pembangunan": {
          "type": "string"
        },
        "utilitas": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "nama_zona",
        "kategori",
        "status",
        "luas_ha"
      ]
    }
  },
  "firestore": {
    "/masterplan_zones/{zoneId}": {
      "schema": "MasterplanZone",
      "description": "Sync parameters and statistics for KIIT Interactive Masterplan zones"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "User inquiries matching ContactFooter form submission"
    },
    "/expressionOfInterests/{eoiId}": {
      "schema": "ExpressionOfInterest",
      "description": "Official expression of interest forms submitted in InvestorCenter"
    },
    "/appointments/{apptId}": {
      "schema": "Appointment",
      "description": "Consultation sessions booked in InvestorCenter scheduler"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User registration documents containing role and profile"
    }
  }
}
